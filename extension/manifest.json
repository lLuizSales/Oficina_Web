{
  "manifest_version": 3,
  "name": "Tradutor Vosk YouTube",
  "version": "1.0",
  "description": "Captura áudio da aba atual para transcrição.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}